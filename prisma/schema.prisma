generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ──────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role      @default(CREATOR)
  plan           Plan      @default(FREE)
  stripeCustomerId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  products      Product[]
  orders        Order[]
  subscriptions Subscription[]
  aiAgents      AIAgent[]
  automations   Automation[]
  analytics     Analytics[]
  members       Member[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Products & Commerce ───────────────────────────

model Product {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?       @db.Text
  price       Float
  currency    String        @default("USD")
  type        ProductType   @default(DIGITAL)
  status      ProductStatus @default(DRAFT)
  imageUrl    String?
  fileUrl     String?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  productId       String
  amount          Float
  currency        String      @default("USD")
  status          OrderStatus @default(PENDING)
  stripePaymentId String?
  customerEmail   String?
  customerName    String?
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("orders")
}

// ── Subscriptions ─────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 Plan
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ── AI Agents ─────────────────────────────────────

model AIAgent {
  id          String      @id @default(cuid())
  userId      String
  name        String
  type        AgentType
  description String?     @db.Text
  config      Json?
  status      AgentStatus @default(INACTIVE)
  lastRunAt   DateTime?
  runsCount   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_agents")
}

// ── Automations ───────────────────────────────────

model Automation {
  id          String           @id @default(cuid())
  userId      String
  name        String
  trigger     String
  actions     Json
  status      AutomationStatus @default(INACTIVE)
  lastRunAt   DateTime?
  runsCount   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("automations")
}

// ── Analytics ─────────────────────────────────────

model Analytics {
  id        String   @id @default(cuid())
  userId    String
  metric    String
  value     Float
  date      DateTime
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("analytics")
}

// ── Team Members ──────────────────────────────────

model Member {
  id        String     @id @default(cuid())
  userId    String
  email     String
  name      String?
  role      MemberRole @default(VIEWER)
  status    String     @default("invited")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
}

// ── Enums ─────────────────────────────────────────

enum Role {
  CREATOR
  ADMIN
  SUPER_ADMIN
}

enum Plan {
  FREE
  GO
  PRO
  PRO_MAX
  AGENCY
}

enum ProductType {
  DIGITAL
  COURSE
  MEMBERSHIP
  SERVICE
  PHYSICAL
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
}

enum AgentType {
  CONTENT_WRITER
  SOCIAL_MANAGER
  EMAIL_MARKETER
  SEO_OPTIMIZER
  ANALYTICS_REPORTER
  CUSTOMER_SUPPORT
  SALES_ASSISTANT
  FUNNEL_BUILDER
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum AutomationStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

enum MemberRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}
